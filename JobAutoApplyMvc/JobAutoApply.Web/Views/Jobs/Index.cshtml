@model JobAutoApply.Web.ViewModels.JobAutomationViewModel
@{
    ViewData["Title"] = "Job Auto Apply";
}

<div class="row g-4">
    <div class="col-lg-7">
        <div class="card shadow-sm">
            <div class="card-body">
                <h2 class="h4 mb-3">Resume-Driven Job Automation</h2>
                <p class="text-muted">Upload resume, extract keywords with Gemini, search Naukri, apply where possible, and store results in Excel.</p>

                <form id="jobAutomationForm" asp-controller="Jobs" asp-action="Run" method="post" enctype="multipart/form-data" class="mt-4">
                    @Html.AntiForgeryToken()
                    <div class="mb-3">
                        <label class="form-label" asp-for="ResumeFile">Resume (.pdf, .docx, .txt)</label>
                        <input class="form-control" asp-for="ResumeFile" type="file" accept=".pdf,.docx,.txt" required />
                        <div id="resumePreviewStatus" class="form-text">Upload a resume to generate preview and auto-fill title.</div>
                    </div>

                    <div id="resumeFilePreviewSection" class="card border mb-3 d-none">
                        <div class="card-body">
                            <h4 class="h6 mb-2">Resume File Preview (PDF)</h4>
                            <iframe id="resumeFilePreviewFrame" title="Resume PDF Preview" style="width: 100%; height: 260px; border: 0;"></iframe>
                        </div>
                    </div>

                    <div id="resumePreviewCard" class="card border bg-light d-none mb-3">
                        <div class="card-body">
                            <h4 class="h6 mb-2">Resume Preview</h4>
                            <pre id="resumePreviewText" class="mb-0" style="max-height: 220px; white-space: pre-wrap; overflow: auto;"></pre>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label" asp-for="JobTitleOverride">Job Title Override (Optional)</label>
                        <input class="form-control" asp-for="JobTitleOverride" placeholder="Example: .NET Developer" />
                    </div>

                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label" asp-for="Email">Naukri Email (first run only)</label>
                            <input class="form-control" asp-for="Email" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label" asp-for="Password">Naukri Password (first run only)</label>
                            <input class="form-control" asp-for="Password" type="password" />
                        </div>
                    </div>
                    <div class="form-text mt-1">Login session is saved after successful sign-in, so you usually do not need to enter credentials every run.</div>

                    <div class="row g-3 mt-1">
                        <div class="col-md-4">
                            <label class="form-label" asp-for="MaxJobs">Max Jobs</label>
                            <input class="form-control" asp-for="MaxJobs" type="number" min="1" max="50" />
                        </div>
                        <div class="col-md-8 d-flex align-items-center mt-4">
                            <div class="form-check">
                                <input class="form-check-input" asp-for="Headless" type="checkbox" />
                                <label class="form-check-label" asp-for="Headless">Run browser in headless mode</label>
                            </div>
                        </div>
                    </div>

                    <button class="btn btn-primary mt-4" type="submit">Start Automation</button>
                </form>
            </div>
        </div>
    </div>

    <div class="col-lg-5">
        <div class="card shadow-sm h-100">
            <div class="card-body">
                <h3 class="h5">Run Summary</h3>

                @if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
                {
                    <div class="alert @(Model.IsError ? "alert-danger" : "alert-success") mt-3">
                        @Model.StatusMessage
                    </div>
                }

                @if (!string.IsNullOrWhiteSpace(Model.ParsedJobTitle))
                {
                    <p class="mb-2"><strong>Selected Job Title:</strong> @Model.ParsedJobTitle</p>
                }

                <div id="autoKeywordSection" class="mt-3 @(Model.Keywords.Count > 0 ? string.Empty : "d-none")">
                    <p class="mb-1"><strong>Resume Keywords:</strong></p>
                    <div id="autoKeywordContainer" class="d-flex flex-wrap gap-2">
                        @foreach (var keyword in Model.Keywords)
                        {
                            <span class="badge text-bg-secondary">@keyword</span>
                        }
                    </div>
                </div>

                <p class="text-muted mt-4 mb-0">Rows with "Apply on company site" are highlighted in the Excel sheet.</p>
            </div>
        </div>
    </div>
</div>

@if (Model.Results.Count > 0)
{
    <div class="card shadow-sm mt-4">
        <div class="card-body">
            <h3 class="h5">Captured Job Records</h3>
            <div class="table-responsive mt-3">
                <table class="table table-striped table-sm align-middle">
                    <thead>
                        <tr>
                            <th>Time</th>
                            <th>Title</th>
                            <th>Company</th>
                            <th>Location</th>
                            <th>Apply Type</th>
                            <th>Status</th>
                            <th>Job Link</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var row in Model.Results)
                        {
                            var rowClass = row.ApplyType.Contains("company site", StringComparison.OrdinalIgnoreCase)
                                ? "table-warning"
                                : string.Empty;
                            <tr class="@rowClass">
                                <td>@row.CapturedAt.LocalDateTime.ToString("yyyy-MM-dd HH:mm")</td>
                                <td>@row.JobTitle</td>
                                <td>@row.Company</td>
                                <td>@row.Location</td>
                                <td>@row.ApplyType</td>
                                <td>@row.Status</td>
                                <td>
                                    @if (!string.IsNullOrWhiteSpace(row.JobUrl))
                                    {
                                        <a href="@row.JobUrl" target="_blank" rel="noopener noreferrer">Open</a>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}

<div class="modal fade" id="jobTitleOptionsModal" tabindex="-1" aria-labelledby="jobTitleOptionsModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="jobTitleOptionsModalLabel">Choose Job Title</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <p class="text-muted mb-3">Based on your resume, select the best matching title for this run.</p>
                <div id="jobTitleOptionsList" class="d-grid gap-2"></div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Skip</button>
                <button type="button" class="btn btn-primary" id="applySelectedTitleButton">Use Selected Title</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        (function () {
            const autoDownloadExcel = @((TempData["AutoDownloadExcel"]?.ToString() == "True") ? "true" : "false");
            const autoDownloadExcelFile = '@(TempData["AutoDownloadExcelFile"]?.ToString() ?? string.Empty)';
            const form = document.getElementById('jobAutomationForm');
            const resumeInput = document.getElementById('ResumeFile');
            const titleInput = document.getElementById('JobTitleOverride');
            const previewCard = document.getElementById('resumePreviewCard');
            const previewText = document.getElementById('resumePreviewText');
            const previewStatus = document.getElementById('resumePreviewStatus');
            const resumeFilePreviewSection = document.getElementById('resumeFilePreviewSection');
            const resumeFilePreviewFrame = document.getElementById('resumeFilePreviewFrame');
            const keywordSection = document.getElementById('autoKeywordSection');
            const keywordContainer = document.getElementById('autoKeywordContainer');
            const jobTitleOptionsModal = document.getElementById('jobTitleOptionsModal');
            const jobTitleOptionsList = document.getElementById('jobTitleOptionsList');
            const applySelectedTitleButton = document.getElementById('applySelectedTitleButton');
            let resumeFilePreviewUrl = null;
            let jobTitleModal = null;

            if (!form || !resumeInput || !titleInput || !previewCard || !previewText || !previewStatus || !resumeFilePreviewSection || !resumeFilePreviewFrame || !keywordSection || !keywordContainer || !jobTitleOptionsModal || !jobTitleOptionsList || !applySelectedTitleButton) {
                return;
            }

            if (window.bootstrap && window.bootstrap.Modal) {
                jobTitleModal = new window.bootstrap.Modal(jobTitleOptionsModal);
            }

            if (autoDownloadExcel && autoDownloadExcelFile) {
                const iframe = document.createElement('iframe');
                iframe.style.display = 'none';
                iframe.src = '@Url.Action("DownloadExcel", "Jobs")?runFile=' + encodeURIComponent(autoDownloadExcelFile) + '&v=' + Date.now();
                document.body.appendChild(iframe);
            }

            function resetPdfPreview() {
                if (resumeFilePreviewUrl) {
                    URL.revokeObjectURL(resumeFilePreviewUrl);
                    resumeFilePreviewUrl = null;
                }

                resumeFilePreviewFrame.removeAttribute('src');
                resumeFilePreviewSection.classList.add('d-none');
            }

            function renderPdfPreview(file) {
                resetPdfPreview();
                if (!file || file.type !== 'application/pdf') {
                    return;
                }

                resumeFilePreviewUrl = URL.createObjectURL(file);
                resumeFilePreviewFrame.src = resumeFilePreviewUrl;
                resumeFilePreviewSection.classList.remove('d-none');
            }

            function renderKeywords(keywords) {
                keywordContainer.innerHTML = '';

                if (!keywords || keywords.length === 0) {
                    keywordSection.classList.add('d-none');
                    return;
                }

                keywords.forEach(function (keyword) {
                    const badge = document.createElement('span');
                    badge.className = 'badge text-bg-secondary';
                    badge.textContent = keyword;
                    keywordContainer.appendChild(badge);
                });

                keywordSection.classList.remove('d-none');
            }

            function showJobTitleOptions(options, suggestedJobTitle) {
                const titles = (options || []).filter(Boolean);
                const fallbackTitle = (suggestedJobTitle || '').trim();
                const mergedTitles = [];

                titles.forEach(function (title) {
                    if (!mergedTitles.some(function (x) { return x.toLowerCase() === title.toLowerCase(); })) {
                        mergedTitles.push(title);
                    }
                });

                if (fallbackTitle && !mergedTitles.some(function (x) { return x.toLowerCase() === fallbackTitle.toLowerCase(); })) {
                    mergedTitles.unshift(fallbackTitle);
                }

                if (mergedTitles.length === 0) {
                    return;
                }

                jobTitleOptionsList.innerHTML = '';

                mergedTitles.forEach(function (title, index) {
                    const optionId = 'jobTitleOption_' + index;
                    const wrapper = document.createElement('div');
                    wrapper.className = 'form-check';

                    const radio = document.createElement('input');
                    radio.className = 'form-check-input';
                    radio.type = 'radio';
                    radio.name = 'jobTitleOption';
                    radio.id = optionId;
                    radio.value = title;
                    radio.checked = index === 0;

                    const label = document.createElement('label');
                    label.className = 'form-check-label';
                    label.setAttribute('for', optionId);
                    label.textContent = title;

                    wrapper.appendChild(radio);
                    wrapper.appendChild(label);
                    jobTitleOptionsList.appendChild(wrapper);
                });

                if (jobTitleModal) {
                    jobTitleModal.show();
                } else {
                    titleInput.value = mergedTitles[0];
                }
            }

            applySelectedTitleButton.addEventListener('click', function () {
                const selected = document.querySelector('input[name="jobTitleOption"]:checked');
                if (selected && selected.value) {
                    titleInput.value = selected.value;
                    previewStatus.textContent = 'Resume analyzed. Selected title has been applied.';
                }

                if (jobTitleModal) {
                    jobTitleModal.hide();
                }
            });

            async function analyzeResume(file) {
                const formData = new FormData();
                formData.append('resumeFile', file);

                const antiForgeryInput = form.querySelector('input[name="__RequestVerificationToken"]');
                if (antiForgeryInput) {
                    formData.append('__RequestVerificationToken', antiForgeryInput.value);
                }

                const response = await fetch('@Url.Action("AnalyzeResume", "Jobs")', {
                    method: 'POST',
                    body: formData,
                    headers: {
                        'X-Requested-With': 'XMLHttpRequest'
                    }
                });

                const payload = await response.json();
                if (!response.ok || !payload.success) {
                    throw new Error(payload.message || 'Resume analysis failed.');
                }

                previewText.textContent = payload.previewText || '';
                previewCard.classList.remove('d-none');

                if (payload.suggestedJobTitle) {
                    titleInput.value = payload.suggestedJobTitle;
                }

                renderKeywords(payload.keywords || []);
                showJobTitleOptions(payload.jobTitleOptions || [], payload.suggestedJobTitle || '');
                previewStatus.textContent = 'Resume analyzed. Please choose a suggested job title.';
            }

            resumeInput.addEventListener('change', async function () {
                const file = resumeInput.files && resumeInput.files[0];
                if (!file) {
                    resetPdfPreview();
                    previewCard.classList.add('d-none');
                    previewText.textContent = '';
                    previewStatus.textContent = 'Upload a resume to generate preview and auto-fill title.';
                    return;
                }

                renderPdfPreview(file);

                previewStatus.textContent = 'Analyzing resume...';

                try {
                    await analyzeResume(file);
                } catch (error) {
                    previewStatus.textContent = error.message || 'Could not analyze resume.';
                }
            });

            window.addEventListener('beforeunload', resetPdfPreview);
        })();
    </script>
}
